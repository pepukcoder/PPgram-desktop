#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROTO_DIR="$ROOT_DIR/protobuf"
OUT_DIR="$ROOT_DIR/PPgram/Protobuf"

if ! command -v protoc >/dev/null 2>&1; then
  echo "error: protoc not found in PATH" >&2
  echo "install protoc and retry" >&2
  exit 1
fi

mkdir -p "$OUT_DIR"
find "$OUT_DIR" -maxdepth 1 -type f -name '*.cs' -delete

mapfile -t PROTO_FILES < <(find "$PROTO_DIR" -maxdepth 1 -type f -name '*.proto' | sort)
if [[ ${#PROTO_FILES[@]} -eq 0 ]]; then
  echo "error: no .proto files found in $PROTO_DIR" >&2
  exit 1
fi

protoc \
  --proto_path="$PROTO_DIR" \
  --csharp_out="$OUT_DIR" \
  "${PROTO_FILES[@]}"

echo "generated ${#PROTO_FILES[@]} proto file(s) into $OUT_DIR"
