<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PPgram.App"
             xmlns:local="using:PPgram"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <FontFamily x:Key="Jetbrains">/Assets/Fonts#JetBrains Mono</FontFamily>

            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://PPgram/Styles/ColorScheme.axaml" />
                <ResourceInclude Source="avares://PPgram/Styles/FocusTheme.axaml" />
                <ResourceInclude Source="avares://PPgram/Styles/Controls/PPButtonTheme.axaml" />
                <ResourceInclude Source="avares://PPgram/Styles/Controls/PPInputFieldTheme.axaml" />
                <ResourceInclude Source="avares://PPgram/Styles/Controls/CornerContainerTheme.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
  
    <Application.Styles>
        <SimpleTheme />
        <StyleInclude Source="avares://PPgram/Styles/Focus.axaml" />
    </Application.Styles>
</Application>
