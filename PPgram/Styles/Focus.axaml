<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="Control">
        <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>

    <Style Selector="Control:focus-visible">
        <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
</Styles>
